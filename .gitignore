# Dependencies (downloaded, never committed)
node_modules/

# Secrets — never commit real environment files
.env
*.env
!*.env.example

# Credential dumps / DB user notes — never commit
*db_user*.txt
*credentials*.txt

# Build output
dist/
build/

# OCR language models — downloaded by tesseract.js at runtime, never committed
*.traineddata

# Logs
*.log
npm-debug.log*

# OS / editor junk
.DS_Store
Thumbs.db
